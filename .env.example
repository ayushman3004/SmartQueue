# ═══════════════════════════════════════════════════
# ServeQ / SmartQueue — Environment Variables
# ═══════════════════════════════════════════════════

# ─── Server ───────────────────────────────────────
PORT=3001
NODE_ENV=development
# NODE_ENV=production  (set this on Render)

# ─── Database ─────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/smart-queue
# MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/smart-queue  (production)

# ─── Auth / JWT ───────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_to_random_string

# ─── Google OAuth ─────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ─── Server URL (for Google OAuth callback) ───────
# On Render, this is auto-set as RENDER_EXTERNAL_URL
# Only set manually if you have a custom domain for the API
# SERVER_URL=https://smartqueue-p629.onrender.com

# ─── Client URL (frontend) ────────────────────────
# Development:
CLIENT_URL=http://localhost:5173
# Production (set on Render):
# CLIENT_URL=https://serveq.tech

# ─── Vite Frontend API URL ────────────────────────
# Development: leave empty to use Vite proxy
VITE_API_URL=
# Production (set on Vercel):
# VITE_API_URL=https://smartqueue-p629.onrender.com

# ─── AI ───────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Twilio (optional, for SMS OTP) ──────────────
# TWILIO_ACCOUNT_SID=your_twilio_account_sid
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_PHONE_NUMBER=+1234567890
